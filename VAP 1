#include <stdio.h>
#include <stdlib.h>

// Definition for a binary tree node.
struct Node {
    int val;
    struct Node* left;
    struct Node* right;
};

// Helper function to create a new node
struct Node* createNode(int key) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->val = key;
    newNode->left = NULL;
    newNode->right = NULL;
    return newNode;
}

// Function to print elements in the given range [low, high]
void printElementsInRange(struct Node* root, int low, int high) {
    if (root == NULL) {
        return;
    }
    
    // If the current node's value is greater than 'low', 
    // there could be valid elements in the left subtree.
    if (root->val > low) {
        printElementsInRange(root->left, low, high);
    }
    
    // If the current node's value is within the range, print it.
    if (root->val >= low && root->val <= high) {
        printf("%d ", root->val);
    }
    
    // Since elements greater than OR EQUAL to the root go to the right,
    // we must check the right subtree even if root->val == high to catch duplicates.
    if (root->val <= high) {
        printElementsInRange(root->right, low, high);
    }
}

int main() {
    // Constructing Example 1 tree: l = 4, h = 24
    struct Node* root = createNode(17);
    root->left = createNode(4);
    root->right = createNode(18);
    root->left->left = createNode(2);
    root->left->right = createNode(9);
    
    printf("Output: ");
    printElementsInRange(root, 4, 24);
    printf("\n");
    
    // Freeing memory would typically go here in a production environment
    return 0;
}
